# Google OAuth — same Client ID as the React app (Web application type)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Secret for signing JWT session tokens (use a long random string in production)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Google Gemini API key for AI treatment advice
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Frontend URL (used in API responses)
FRONTEND_URL=http://localhost:3000

# Comma-separated allowed CORS origins (production: your Vercel/Render frontend URL)
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Path to trained model (relative to api/ directory)
MODEL_PATH=../saved_models/model_v1.keras
